    {
      "id": "personnel.driver.takeover.attention",
      "name_zh": "注意力状态",
      "name_en": "Attention State",
      "level": 5,
      "parent_id": "personnel.driver.takeover",
      "spec_section": "6.3.1.1.1",
      "description_zh": "可被 ADS 识别的驾驶员/DDT 后援用户的注意力状态（如闭眼、哈欠、头部姿态异常、接打手持电话或抽烟等有意识的头部或身体运动等），以此来判断其是否具备接管能力。",
      "requirement_template": "应说明 ADS 允许或不允许的驾驶员/DDT 后援用户注意力状态。应说明注意力状态的监测方式和指标情况。"
    },
    {
      "id": "personnel.driver.takeover.other",
      "name_zh": "其他状态",
      "name_en": "Other Fallback-Affecting State",
      "level": 5,
      "parent_id": "personnel.driver.takeover",
      "spec_section": "6.3.1.1.2",
      "description_zh": "其他影响驾驶员/DDT 后援用户接管汽车的状态（如无意识的头部或身体动作、健康状况异常、有意识的人机交互动作等）。"
    },
    {
